# Tavily web search (optional — without it the engine falls back to Wikipedia only)
TAVILY_API_KEY=

# Alibaba Qwen
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# Xiaomi MiMo
XIAOMI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Generic OpenAI-compatible provider
# Replace PROVIDER_NAME with your provider name (e.g. mymodel):
#   {PROVIDER_NAME}_API_KEY=sk-xxx
#   {PROVIDER_NAME}_BASE_URL=https://api.example.com/v1
#   {PROVIDER_NAME}_MODEL=model-name
# Then run: veritas verify --claim "..." --provider provider_name --json
